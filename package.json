{
    "name": "langium-ai",
    "private": true,
    "version": "0.0.1",
    "description": "Monorepo for Langium AI and its associated projects",
    "scripts": {
        "build": "npm run build --workspaces",
        "test": "npm run test --workspaces",
        "test:ci": "npm run test --workspaces",
        "clean": "npm run clean --workspaces",
        "watch": "npm run watch --workspaces",
        "lint": "oxlint .",
        "format": "biome format .",
        "format:fix": "biome format --write .",
        "knip": "knip"
    },
    "type": "module",
    "author": {
        "name": "TypeFox",
        "url": "https://www.typefox.io"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "license": "MIT",
    "workspaces": [
        "packages/langium-ai-tools",
        "packages/langium-ai-mcp",
        "packages/cli",
        "packages/examples/*"
    ],
    "devDependencies": {
        "@biomejs/biome": "^1.9.0",
"@types/node": "^25.5.0",
        "knip": "^6.0.0",
        "oxlint": "^1.3.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    }
}
