{
  "name": "langium-ai",
  "version": "0.3.0",
  "description": "AI application development tooling for Langium-based DSL projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eclipse-langium/langium-ai.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/eclipse-langium/langium-ai/issues",
  "type": "module",
  "bin": {
    "lai": "dist/lai.js"
  },
  "files": [
    "dist/lai.js"
  ],
  "scripts": {
    "build": "npm run embed-templates && tsc && node esbuild.js",
    "embed-templates": "node scripts/embed-templates.js",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "clean": "rimraf ./dist"
  },
  "keywords": [
    "langium",
    "ai",
    "llm",
    "dsl",
    "cli"
  ],
  "author": "Langium Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "langium-ai-tools": "~5.0.4",
    "ora": "^9.4.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "esbuild": ">=0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
